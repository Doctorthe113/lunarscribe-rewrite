{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "core:window:allow-set-title",
    {
      "identifier": "fs:allow-document-read",
      "allow": [
        {
          "path": "$DOCUMENT/*"
        }
      ]
    },
    {
      "identifier": "fs:allow-document-write",
      "allow": [
        {
          "path": "$DOCUMENT/lunarscribe/*"
        }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        {
          "path": "$DOCUMENT/*"
        }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        {
          "path": "$DOCUMENT/*"
        }
      ]
    },
    {
      "identifier": "fs:allow-write",
      "allow": [
        {
          "path": "$DOWNLOAD/*"
        }
      ]
    },
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "https://dropbox.com/*"
        },
        {
          "url": "custom:*"
        }
      ]
    }
  ]
}